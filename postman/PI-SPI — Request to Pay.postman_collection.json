  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate a unique identifiantDemandePaiement for every request.",
          "// Format: RTP-YYYYMMDDHHmmss-XXXXXX (UTC timestamp + 6-char random suffix).",
          "// BCEAO DemandePaiement constraint: max 35 chars — generated value is 25 chars.",
          "const now = new Date();",
          "const pad = n => String(n).padStart(2, '0');",
          "const ts = '' +",
          "  now.getUTCFullYear() +",
          "  pad(now.getUTCMonth() + 1) +",
          "  pad(now.getUTCDate()) +",
          "  pad(now.getUTCHours()) +",
          "  pad(now.getUTCMinutes()) +",
          "  pad(now.getUTCSeconds());",
          "const rand = Array.from({ length: 6 }, () =>",
          "  'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'.charAt(Math.floor(Math.random() * 36))",
          ").join('');",
          "pm.collectionVariables.set('identifiantDemandePaiement', `RTP-${ts}-${rand}`);"
        ]
      }
    }
  ],
